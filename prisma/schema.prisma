generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  cnpj      String    @unique
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id           Int     @id @default(autoincrement())
  name         String
  description  String?
  unity        String
  currentStock Int     @default(0)
  minimunStock Int     @default(0)
  categoryId   Int
  supplierId   Int

  category Category @relation(fields: [categoryId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  createdAt      DateTime        @default(now())
  stockMoviments StockMovement[]

  @@index([categoryId])
  @@index([supplierId])
}

enum Type {
  IN
  OUT
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  type      Type
  quantity  Int
  notes     String?
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@index([productId])
}
